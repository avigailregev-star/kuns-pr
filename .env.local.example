# ============================================================
# קובץ משתני סביבה לדוגמה
# העתק קובץ זה לשם .env.local ומלא את הערכים
# ============================================================

# --- Google Sheets ---
# מזהה הגיליון (מה-URL: /spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# אימייל של חשבון השירות (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# מפתח פרטי של חשבון השירות (העתק מקובץ ה-JSON, כולל BEGIN/END)
# שים לב: יש לעטוף במרכאות ולהחליף ירידות שורה ב-\n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Make (Integromat) ---
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id

# --- NextAuth ---
# מחרוזת אקראית לאבטחה (הרץ: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- ניהול ---
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here
